OPENAI_API_KEY=sk-your-openai-api-key
# Or use the alias if you prefer:
# ADVANCED_AI_API_KEY=sk-your-openai-api-key
AI_MODEL=gpt-5.4-mini
PORT=8000
JWT_SECRET=your-long-random-secret

# Optional Supabase replication support
SUPABASE_URL=https://your-supabase-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Frontend/app URL used in auth emails and OAuth redirects
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:8000

# Email verification/password reset delivery. In development, emails are logged when no provider is configured.
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_PROVIDER=resend
EMAIL_FROM=VentureLift <no-reply@yourdomain.com>
RESEND_API_KEY=re_your-resend-api-key
# Or use SendGrid instead:
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Google OAuth login
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/oauth/google/callback

# Optional production billing
STRIPE_SECRET_KEY=sk_test_or_live_your-stripe-secret-key
STRIPE_PRICE_ID=price_your-subscription-price-id
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Optional monitoring
SENTRY_DSN=https://your-backend-sentry-dsn
VITE_SENTRY_DSN=https://your-frontend-sentry-dsn
